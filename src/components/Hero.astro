---
---

<section class="hero" id="hero">
  <div class="hero-inner container">
    <div class="hero-content">
      <p class="hero-label">Deep Work · Garage Vibe · Maker Community</p>
      <h1>Der inCHURbation Space for Makers.</h1>
      <p class="hero-sub">Deep Work meets Garage Vibe im neuen Epizentrum der Churer Tech-Szene. Exklusiv für KI-affine Unternehmer/innen, IT-Consultants und Tech-Visionäre.</p>
      <div class="hero-actions">
        <a href="#mietgesuch" class="btn btn-primary">Besichtigung vereinbaren</a>
        <a href="#pricing" class="btn btn-outline-light">Workspace-Optionen</a>
      </div>
      <div class="hero-badge">
        <span class="badge-icon">&#x1F525;</span>
        <span>Early Adopter Deal: Vorbezug ab 1. April mit 20&nbsp;% Rabatt</span>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-img-main">
        <img src="/images/coworking-space.jpg" alt="FactorAI Coworking Space mit Bergblick" />
      </div>
      <div class="hero-img-grid">
        <img src="/images/office-montalin.jpg" alt="Einzelbüro Montalin" />
        <img src="/images/kitchen.jpg" alt="Gemeinschaftsküche mit Aussicht" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--color-dark);
    padding: 80px 24px 100px;
    overflow: hidden;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .hero-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 20px;
    opacity: 0.9;
  }
  h1 {
    font-size: 52px;
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-white);
    margin-bottom: 24px;
  }
  .hero-sub {
    font-size: 17px;
    color: rgba(255,255,255,0.6);
    margin-bottom: 32px;
    max-width: 460px;
    line-height: 1.7;
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(9,138,203,0.12);
    border: 1px solid rgba(9,138,203,0.25);
    border-radius: var(--radius-full);
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-primary);
  }
  .badge-icon {
    font-size: 16px;
  }
  .hero-visual {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .hero-img-main {
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .hero-img-main img {
    width: 100%;
    height: 300px;
    object-fit: cover;
  }
  .hero-img-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .hero-img-grid img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    border-radius: var(--radius-md);
  }
  @media (max-width: 1024px) {
    h1 { font-size: 40px; }
  }
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    h1 { font-size: 32px; }
    .hero-img-main img { height: 220px; }
    .hero-img-grid img { height: 120px; }
    .hero-badge {
      font-size: 13px;
      padding: 8px 16px;
    }
  }
</style>
