---
const features = [
  {
    key: 'exchange',
    title: 'AI Exchange Space',
    meta: 'Ab 18:30 Uhr',
    desc: 'Networking mit Jura-Kaffee, Lounge und Marshall-Amp für spontane Jam-Sessions. Hier leben wir den Garage Vibe.',
    big: true,
  },
  {
    key: 'focus',
    title: 'Deep-Work-Räume',
    meta: 'Klimatisiert · Ruhig',
    desc: 'Ergonomisches Mobiliar und dedizierte Rückzugsorte für ungestörtes, konzentriertes Arbeiten.',
  },
  {
    key: 'tech',
    title: 'Tech-Hub',
    meta: '98-Zoll-Screen',
    desc: 'Zentrale Bühne für Hackathons, Use-Case-Reviews und Präsentationen deiner nächsten KI-Iteration.',
  },
  {
    key: 'standoff',
    title: 'Sitzungszimmer für AI Standoffs',
    meta: '10 stehend · 6 sitzend',
    desc: 'Höhenverstellbarer Tisch, 55-Zoll-Flatscreen und Workshopwall für fokussierte Meetings.',
  },
  {
    key: 'kitchen',
    title: 'Gemeinschaftsküche',
    meta: 'Jura-Kaffeevollautomat',
    desc: 'Neuwertig, mit Stehtisch für den Austausch und Panoramablick auf die Bündner Bergwelt.',
  },
  {
    key: 'location',
    title: 'Top Lage Chur Nord',
    meta: '300 m zum Bahnhof',
    desc: 'Autobahnanschluss Chur Nord, Bushaltestelle 50 m, Coop und Apotheke 200 m, Rhein als Naherholung.',
  },
];
---

<section class="infra section" id="ausstattung">
  <div class="container">
    <div class="infra-head">
      <div>
        <p class="label">Die Infrastruktur</p>
        <h2 class="section-title">Alles für deinen <em>Workflow</em></h2>
      </div>
      <p class="section-sub">Sichtbeton, Echtholz-Parkett und 210&nbsp;m² Dachgeschoss &ndash; kompromisslos auf Fokus und Austausch optimiert.</p>
    </div>

    <ul class="bento">
      {features.map((f, i) => (
        <li class={`bento-tile ${f.big ? 'bento-tile-big' : ''}`} data-key={f.key}>
          <span class="bento-index">{String(i + 1).padStart(2, '0')}</span>
          <div class="bento-icon" aria-hidden="true">
            {f.key === 'exchange' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>}
            {f.key === 'focus' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>}
            {f.key === 'tech' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="14" rx="2"/><path d="M8 22h8"/><path d="M12 18v4"/></svg>}
            {f.key === 'standoff' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="7" r="4"/><circle cx="17" cy="9" r="3"/><path d="M2 21v-2a6 6 0 0 1 12 0v2"/><path d="M14 21v-1a5 5 0 0 1 8-4"/></svg>}
            {f.key === 'kitchen' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2v4"/><path d="M10 2v4"/><path d="M14 2v4"/><rect x="4" y="6" width="12" height="10" rx="2"/><path d="M16 10h4a2 2 0 0 1 0 4h-4"/><path d="M8 16v6"/><path d="M12 16v6"/></svg>}
            {f.key === 'location' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-7-7.2-7-13a7 7 0 0 1 14 0c0 5.8-7 13-7 13z"/><circle cx="12" cy="9" r="2.5"/></svg>}
          </div>
          <div class="bento-body">
            <p class="bento-meta">{f.meta}</p>
            <h3>{f.title}</h3>
            <p class="bento-desc">{f.desc}</p>
          </div>
        </li>
      ))}
    </ul>

    <div class="infra-image">
      <img src="/images/skylight-lounge.jpg" alt="FactorAI Rückzugsraum mit Oblichtern und Bergblick in Chur Nord" loading="lazy" decoding="async" width="1140" height="400" />
      <div class="infra-image-caption">
        <span class="caption-dot" aria-hidden="true"></span>
        <span>Skylight-Lounge &middot; Stelleweg 4, Chur Nord</span>
      </div>
    </div>
  </div>
</section>

<style>
  .infra {
    background: linear-gradient(180deg, var(--color-gray-100) 0%, #F8F9FB 100%);
    position: relative;
  }
  .infra-head {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: 48px;
    align-items: end;
    margin-bottom: 48px;
    max-width: 1040px;
  }
  .label {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 2.5px;
    margin-bottom: 12px;
  }
  .section-title {
    font-size: clamp(32px, 4.5vw, 48px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }
  .section-title em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-primary);
  }
  .section-sub {
    font-size: 16px;
    color: var(--color-gray-500);
    line-height: 1.65;
    max-width: 440px;
    justify-self: end;
  }

  .bento {
    list-style: none;
    padding: 0;
    margin: 0 0 64px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: minmax(220px, auto);
    gap: 16px;
  }
  .bento-tile {
    position: relative;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-md);
    padding: 28px 26px 30px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    transition: transform 0.3s cubic-bezier(.2,.8,.2,1), border-color 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }
  .bento-tile::before {
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-primary), transparent);
    opacity: 0;
    transform: translateX(-100%);
    transition: opacity 0.4s ease, transform 0.6s cubic-bezier(.2,.8,.2,1);
  }
  .bento-tile:hover {
    transform: translateY(-3px);
    border-color: rgba(9,138,203,0.35);
    box-shadow: 0 20px 40px -20px rgba(17,17,24,0.1);
  }
  .bento-tile:hover::before {
    opacity: 1;
    transform: translateX(0);
  }
  .bento-tile-big {
    grid-column: span 2;
    grid-row: span 1;
    background:
      radial-gradient(70% 90% at 100% 0%, rgba(9,138,203,0.18), transparent 70%),
      var(--color-black);
    color: rgba(255,255,255,0.75);
    border-color: transparent;
    padding: 36px 36px 40px;
  }
  .bento-tile-big .bento-meta {
    color: var(--color-primary);
  }
  .bento-tile-big .bento-index {
    color: rgba(255,255,255,0.25);
  }
  .bento-tile-big .bento-icon {
    background: rgba(9,138,203,0.15);
    color: var(--color-primary);
    border-color: rgba(9,138,203,0.35);
  }

  .bento-index {
    position: absolute;
    top: 22px;
    right: 24px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--color-gray-200);
    font-variant-numeric: tabular-nums;
  }
  .bento-icon {
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-sm);
    color: var(--color-primary);
    background: var(--color-primary-light);
    flex-shrink: 0;
  }
  .bento-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: auto;
  }
  .bento-meta {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-primary);
  }
  .bento-tile h3 {
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-black);
    line-height: 1.25;
  }
  .bento-tile-big h3 {
    color: var(--color-white);
    font-size: 26px;
    line-height: 1.2;
  }
  .bento-desc {
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--color-gray-500);
  }
  .bento-tile-big .bento-desc {
    color: rgba(255,255,255,0.55);
    font-size: 15.5px;
    max-width: 52ch;
  }

  .infra-image {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .infra-image img {
    width: 100%;
    height: 400px;
    object-fit: cover;
    display: block;
  }
  .infra-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(12,12,18,0.55) 100%);
    pointer-events: none;
  }
  .infra-image-caption {
    position: absolute;
    bottom: 22px;
    left: 24px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    background: rgba(12,12,18,0.55);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-full);
    font-size: 12px;
    color: rgba(255,255,255,0.9);
    z-index: 1;
  }
  .caption-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
  }

  @media (max-width: 1024px) {
    .infra-head {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .section-sub {
      justify-self: start;
    }
    .bento {
      grid-template-columns: repeat(2, 1fr);
    }
    .bento-tile-big {
      grid-column: span 2;
    }
  }
  @media (max-width: 640px) {
    .bento {
      grid-template-columns: 1fr;
    }
    .bento-tile-big {
      grid-column: span 1;
    }
    .infra-image img { height: 260px; }
  }
</style>
