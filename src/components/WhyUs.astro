---
const features = [
  {
    icon: '🎯',
    title: 'Fokus pur',
    desc: 'Klimatisierte Räume, ergonomisches Mobiliar und Rückzugsorte für ungestörtes Deep Work.'
  },
  {
    icon: '📺',
    title: 'Tech-Hub',
    desc: 'Ein 98-Zoll-Screen für deinen nächsten Hackathon, Use-Case-Entwicklungen und Präsentationen.'
  },
  {
    icon: '🎸',
    title: 'AI Exchange Space',
    desc: 'Networking ab 18:30 Uhr. Mit Jura-Kaffee, Lounge und einem Marshall-Amp für spontane Jam-Sessions. Hier leben wir den Garage Vibe!'
  },
  {
    icon: '⚡',
    title: 'Sitzungszimmer für AI Standoffs',
    desc: 'Platz für 10 Personen im Stehen oder 6 im Sitzen. Höhenverstellbarer Tisch, 55-Zoll-Flatscreen und Workshopwall für fokussierte Meetings und Workshops.'
  },
  {
    icon: '🍳',
    title: 'Gemeinschaftsküche',
    desc: 'Neuwertig, mit Stehtisch für den gemeinsamen Austausch und fantastischer Aussicht auf die Bergwelt.'
  },
  {
    icon: '📍',
    title: 'Top Lage',
    desc: 'Direkt beim Autobahnanschluss Chur Nord. Bushaltestelle (50 m), Migros und der Rhein als Naherholungsgebiet um die Ecke.'
  },
];
---

<section class="infra section" id="ausstattung">
  <div class="container">
    <p class="label">Die Infrastruktur</p>
    <h2 class="section-title">Alles für deinen Workflow</h2>
    <p class="section-sub">Unsere Räumlichkeiten im Dachgeschoss verbinden innovatives Design &ndash; Sichtbeton, Echtholz-Parkett &ndash; mit absoluter Funktionalität.</p>
    <div class="features-grid">
      {features.map(f => (
        <div class="feature-card">
          <span class="feature-icon">{f.icon}</span>
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
    <div class="infra-image">
      <img src="/images/skylight-lounge.jpg" alt="FactorAI Rückzugsraum mit Oblichtern und Bergblick" />
    </div>
  </div>
</section>

<style>
  .infra {
    background: var(--color-gray-100);
  }
  .label {
    text-align: center;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }
  .section-title {
    text-align: center;
    font-size: 40px;
    font-weight: 700;
    margin-bottom: 16px;
  }
  .section-sub {
    text-align: center;
    font-size: 16px;
    color: var(--color-gray-500);
    max-width: 560px;
    margin: 0 auto 56px;
    line-height: 1.7;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 56px;
  }
  .feature-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-md);
    padding: 32px 24px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .feature-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.06);
  }
  .feature-icon {
    font-size: 32px;
    display: block;
    margin-bottom: 16px;
  }
  .feature-card h3 {
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .feature-card p {
    font-size: 14px;
    line-height: 1.7;
    color: var(--color-gray-500);
  }
  .infra-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .infra-image img {
    width: 100%;
    height: 360px;
    object-fit: cover;
  }
  @media (max-width: 1024px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .section-title { font-size: 28px; }
    .features-grid { grid-template-columns: 1fr; }
    .infra-image img { height: 240px; }
  }
</style>
