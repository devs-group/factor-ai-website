---
---

<section class="pricing section section-dark" id="pricing">
  <div class="container">
    <p class="label">Deine Workspace-Optionen</p>
    <h2 class="pricing-title">Feste Plätze, echte Community</h2>
    <p class="pricing-sub">Rundum-sorglos-Miete &ndash; Strom, Nebenkosten, Highspeed-WiFi, Reinigung der Gemeinschaftsflächen und hochwertiges Mobiliar immer inklusive. Bei uns gibt es keine anonymen Flex-Desks &ndash; wir setzen auf feste Arbeitsplätze für eine konstante, vertraute Community.</p>

    <div class="pricing-grid pricing-grid-2">
      <!-- Fix-Desk Shared Office -->
      <div class="pricing-card">
        <div class="card-badge card-badge-avail">Shared Office</div>
        <div class="card-image">
          <img src="/images/coworking-space.jpg" alt="Fix-Desk im Shared Office" />
        </div>
        <div class="pricing-body">
          <h3>Fix-Desk &laquo;#sharedoffice&raquo;</h3>
          <p class="card-desc">Dein fester Schreibtisch im Gemeinschaftsbüro &ndash; ideal für Austausch, Networking und maximale Flexibilität.</p>
          <div class="pricing-header">
            <span class="price">CHF 249.&ndash;</span>
            <span class="price-period">/Monat</span>
          </div>
          <ul class="features">
            <li>Monatlich kündbar</li>
            <li>Höhenverstellbarer Tisch &amp; ergonomischer Bürostuhl</li>
            <li>Hochwertige Stehlampe &amp; Highspeed-WiFi</li>
            <li>Strom &amp; Nebenkosten inklusive</li>
            <li>Reinigung der Gemeinschaftsflächen</li>
          </ul>
          <a href="#mietgesuch" class="btn btn-outline-light pricing-btn">Fix-Desk anfragen</a>
        </div>
      </div>

      <!-- Einzelbüro Premium -->
      <div class="pricing-card featured">
        <div class="card-badge">Premium</div>
        <div class="card-image">
          <img src="/images/einzelbuero-oberland.jpg" alt="Einzelbüro Premium mit Bergblick" />
        </div>
        <div class="pricing-body">
          <h3>Einzelbüro Premium</h3>
          <p class="card-sub">Oberland 1 &amp; 2 (bis 2 Personen) &middot; Montalin 3 (bis 3 Personen)</p>
          <p class="card-desc">Dein privates Hauptquartier für Deep Work &ndash; komplett möbliert, repräsentativ und mit inspirierender Aussicht in die Bündner Bergwelt.</p>
          <div class="pricing-header">
            <span class="price">CHF 789.&ndash;</span>
            <span class="price-period">/Monat</span>
          </div>
          <ul class="features">
            <li>Alle 3 Monate kündbar</li>
            <li>Höhenverstellbarer Tisch &amp; ergonomischer Bürostuhl</li>
            <li>Hochwertige Stehlampe &amp; Highspeed-WiFi</li>
            <li>Strom &amp; Nebenkosten inklusive</li>
            <li>Reinigung der Gemeinschaftsflächen</li>
          </ul>
          <a href="#mietgesuch" class="btn btn-primary pricing-btn">Einzelbüro anfragen</a>
        </div>
      </div>
    </div>

    <div class="inclusions">
      <h3 class="inclusions-title">Immer inklusive &ndash; unser Rundum-sorglos-Paket</h3>
      <div class="inclusions-grid">
        <div class="inclusion"><span class="check">✓</span>Höhenverstellbarer Tisch &amp; ergonomischer Bürostuhl</div>
        <div class="inclusion"><span class="check">✓</span>Hochwertige Stehlampe &amp; Highspeed-WiFi</div>
        <div class="inclusion"><span class="check">✓</span>Strom &amp; Nebenkosten inklusive</div>
        <div class="inclusion"><span class="check">✓</span>Reinigung der Gemeinschaftsflächen (Küche/WCs)</div>
      </div>
    </div>
  </div>
</section>

<style>
  .label {
    text-align: center;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }
  .pricing-title {
    text-align: center;
    font-size: 40px;
    font-weight: 700;
    margin-bottom: 16px;
  }
  .pricing-sub {
    text-align: center;
    font-size: 16px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 56px;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }
  .pricing-grid {
    display: grid;
    gap: 24px;
    align-items: start;
  }
  .pricing-grid-2 {
    grid-template-columns: repeat(2, 1fr);
    max-width: 860px;
    margin: 0 auto;
  }
  .pricing-card {
    background: var(--color-dark-surface);
    border: 1px solid var(--color-dark-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }
  .pricing-card:hover {
    transform: translateY(-4px);
    border-color: rgba(9,138,203,0.3);
  }
  .pricing-card.featured {
    border-color: var(--color-primary);
  }
  .card-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    background: var(--color-primary);
    color: var(--color-white);
    padding: 6px 14px;
    border-radius: var(--radius-full);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 2;
  }
  .card-badge-avail {
    background: rgba(9,138,203,0.85);
  }
  .card-image img {
    width: 100%;
    height: 220px;
    object-fit: cover;
  }
  .pricing-body {
    padding: 28px;
  }
  .pricing-body h3 {
    font-size: 22px;
    font-weight: 600;
    margin-bottom: 6px;
    color: var(--color-white);
  }
  .card-sub {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-primary);
    margin-bottom: 12px;
  }
  .card-desc {
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255,255,255,0.5);
    margin-bottom: 24px;
  }
  .pricing-header {
    margin-bottom: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--color-dark-border);
  }
  .price {
    font-size: 36px;
    font-weight: 700;
    color: var(--color-primary);
  }
  .price-period {
    font-size: 14px;
    color: rgba(255,255,255,0.4);
  }
  .features {
    list-style: none;
    padding: 0;
    margin-bottom: 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .features li {
    font-size: 14px;
    color: rgba(255,255,255,0.6);
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .features li::before {
    content: '✓';
    color: var(--color-primary);
    font-weight: 700;
    font-size: 13px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .pricing-btn {
    width: 100%;
    justify-content: center;
  }

  .inclusions {
    margin-top: 56px;
    background: rgba(9,138,203,0.08);
    border: 1px solid rgba(9,138,203,0.2);
    border-radius: var(--radius-lg);
    padding: 40px 48px;
  }
  .inclusions-title {
    text-align: center;
    font-size: 20px;
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: 28px;
  }
  .inclusions-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px 40px;
    max-width: 760px;
    margin: 0 auto;
  }
  .inclusion {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15px;
    color: rgba(255,255,255,0.75);
  }
  .check {
    color: var(--color-primary);
    font-weight: 700;
    font-size: 16px;
  }

  @media (max-width: 1024px) {
    .pricing-grid-2 {
      grid-template-columns: 1fr;
      max-width: 440px;
    }
  }
  @media (max-width: 768px) {
    .pricing-title { font-size: 28px; }
    .inclusions {
      padding: 28px 20px;
    }
    .inclusions-grid { grid-template-columns: 1fr; }
  }
</style>
