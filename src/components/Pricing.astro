---
---

<section class="pricing section section-dark" id="pricing">
  <div class="container">
    <div class="pricing-head">
      <p class="label">Deine Workspace-Optionen</p>
      <h2 class="pricing-title">Feste Plätze, <em>echte</em> Community</h2>
      <p class="pricing-sub">Rundum-sorglos-Miete &ndash; Strom, Nebenkosten, Highspeed-WiFi, Reinigung und hochwertiges Mobiliar immer inklusive. Keine anonymen Flex-Desks &ndash; feste Arbeitsplätze für eine konstante, vertraute Community.</p>
    </div>

    <div class="pricing-grid pricing-grid-2">
      <!-- Fix-Desk Shared Office -->
      <article class="pricing-card">
        <div class="card-badge card-badge-avail">Shared Office</div>
        <div class="card-image">
          <img src="/images/office-art-monkey.jpg" alt="Fix-Desk im Shared Office mit Gemeinschaftstisch in Chur Nord" loading="lazy" decoding="async" width="450" height="240" />
        </div>
        <div class="pricing-body">
          <header class="card-head">
            <h3>Fix-Desk <span class="card-hash">#sharedoffice</span></h3>
            <p class="card-desc">Dein fester Schreibtisch im Gemeinschaftsbüro &ndash; ideal für Austausch, Networking und maximale Flexibilität.</p>
          </header>
          <div class="pricing-header">
            <div class="price-line">
              <span class="price-currency">CHF</span>
              <span class="price">249.&ndash;</span>
              <span class="price-period">/ Monat</span>
            </div>
            <span class="price-term">Monatlich kündbar</span>
          </div>
          <ul class="features">
            <li>Höhenverstellbarer Tisch &amp; ergonomischer Bürostuhl</li>
            <li>Hochwertige Stehlampe &amp; Highspeed-WiFi</li>
            <li>Strom &amp; Nebenkosten inklusive</li>
            <li>Reinigung der Gemeinschaftsflächen</li>
          </ul>
          <a href="#mietgesuch" class="btn btn-outline-light pricing-btn">Fix-Desk anfragen <span aria-hidden="true">&rarr;</span></a>
        </div>
      </article>

      <!-- Einzelbüro Premium -->
      <article class="pricing-card featured">
        <div class="card-badge">Premium</div>
        <div class="card-image">
          <img src="/images/office-desk-art.jpg" alt="Einzelbüro Premium mit Designerkunst und Bergblick in Chur" loading="lazy" decoding="async" width="450" height="240" />
        </div>
        <div class="pricing-body">
          <header class="card-head">
            <h3>Einzelbüro <span class="card-hash">Premium</span></h3>
            <p class="card-sub">Oberland 1 &amp; 2 &middot; bis 2 Pers. &nbsp;|&nbsp; Montalin 3 &middot; bis 3 Pers.</p>
            <p class="card-desc">Dein privates Hauptquartier für Deep Work &ndash; komplett möbliert, repräsentativ und mit inspirierender Aussicht in die Bündner Bergwelt.</p>
          </header>
          <div class="pricing-header">
            <div class="price-line">
              <span class="price-currency">CHF</span>
              <span class="price">789.&ndash;</span>
              <span class="price-period">/ Monat</span>
            </div>
            <span class="price-term">Alle 3 Monate kündbar</span>
          </div>
          <ul class="features">
            <li>Höhenverstellbarer Tisch &amp; ergonomischer Bürostuhl</li>
            <li>Hochwertige Stehlampe &amp; Highspeed-WiFi</li>
            <li>Strom &amp; Nebenkosten inklusive</li>
            <li>Reinigung der Gemeinschaftsflächen</li>
          </ul>
          <a href="#mietgesuch" class="btn btn-primary pricing-btn">Einzelbüro anfragen <span aria-hidden="true">&rarr;</span></a>
        </div>
      </article>
    </div>

    <section class="inclusions" aria-labelledby="inclusions-title">
      <div class="inclusions-head">
        <p class="inclusions-eyebrow">Rundum-sorglos-Paket</p>
        <h3 class="inclusions-title" id="inclusions-title">Immer inklusive</h3>
      </div>
      <ul class="inclusions-grid">
        <li class="inclusion">
          <svg class="inclusion-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10h18"/><path d="M5 10V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v4"/><path d="M6 14v6"/><path d="M18 14v6"/><path d="M3 14h18"/></svg>
          <div>
            <p class="inclusion-title">Ergonomisches Setup</p>
            <p class="inclusion-text">Höhenverstellbarer Tisch &amp; Bürostuhl</p>
          </div>
        </li>
        <li class="inclusion">
          <svg class="inclusion-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5a7 7 0 0 1 14 0"/><path d="M8.5 15.5a3.5 3.5 0 0 1 7 0"/><circle cx="12" cy="19" r="1.2"/><path d="M2 9a10 10 0 0 1 20 0"/></svg>
          <div>
            <p class="inclusion-title">Highspeed-WiFi</p>
            <p class="inclusion-text">Plus hochwertige Stehlampe am Platz</p>
          </div>
        </li>
        <li class="inclusion">
          <svg class="inclusion-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L4 14h7l-1 8 9-12h-7z"/></svg>
          <div>
            <p class="inclusion-title">Strom &amp; Nebenkosten</p>
            <p class="inclusion-text">Keine versteckten Zusatzkosten</p>
          </div>
        </li>
        <li class="inclusion">
          <svg class="inclusion-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 7l-6.5 6.5-4-4L3 17"/><path d="M21 7v6"/><path d="M21 7h-6"/></svg>
          <div>
            <p class="inclusion-title">Reinigung inklusive</p>
            <p class="inclusion-text">Küche &amp; WCs werden regelmässig gepflegt</p>
          </div>
        </li>
      </ul>
    </section>
  </div>
</section>

<style>
  .pricing-head {
    max-width: 720px;
    margin: 0 auto 64px;
    text-align: center;
  }
  .label {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 2.5px;
    margin-bottom: 16px;
  }
  .pricing-title {
    font-size: clamp(32px, 4.5vw, 44px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }
  .pricing-title em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-primary);
  }
  .pricing-sub {
    font-size: 16px;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    max-width: 620px;
    margin: 0 auto;
  }
  .pricing-grid {
    display: grid;
    gap: 24px;
    align-items: stretch;
  }
  .pricing-grid-2 {
    grid-template-columns: repeat(2, 1fr);
    max-width: 900px;
    margin: 0 auto;
  }
  .pricing-card {
    background: var(--color-dark-surface);
    border: 1px solid var(--color-dark-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
    transition: transform 0.4s cubic-bezier(.2,.8,.2,1), border-color 0.3s ease, box-shadow 0.4s ease;
    display: flex;
    flex-direction: column;
  }
  .pricing-card:hover {
    transform: translateY(-6px);
    border-color: rgba(9,138,203,0.35);
    box-shadow: 0 30px 60px -20px rgba(9,138,203,0.25);
  }
  .pricing-card.featured {
    border-color: rgba(9,138,203,0.55);
    background: linear-gradient(180deg, rgba(9,138,203,0.06) 0%, var(--color-dark-surface) 40%);
  }
  .card-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background: var(--color-primary);
    color: var(--color-white);
    padding: 6px 14px;
    border-radius: var(--radius-full);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    z-index: 2;
    backdrop-filter: blur(8px);
  }
  .card-badge-avail {
    background: rgba(9,138,203,0.85);
  }
  .card-image {
    position: relative;
    overflow: hidden;
  }
  .card-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, rgba(12,12,18,0.55) 100%);
    pointer-events: none;
  }
  .card-image img {
    width: 100%;
    height: 240px;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(.2,.8,.2,1);
  }
  .pricing-card:hover .card-image img {
    transform: scale(1.05);
  }
  .pricing-body {
    padding: 32px 28px 28px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 24px;
  }
  .card-head {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .pricing-body h3 {
    font-size: 22px;
    font-weight: 600;
    color: var(--color-white);
    letter-spacing: -0.01em;
  }
  .card-hash {
    font-weight: 400;
    color: var(--color-primary);
    font-family: 'Inter', monospace;
  }
  .card-sub {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.01em;
  }
  .card-desc {
    font-size: 14.5px;
    line-height: 1.7;
    color: rgba(255,255,255,0.55);
  }
  .pricing-header {
    padding: 20px 0;
    border-top: 1px solid var(--color-dark-border);
    border-bottom: 1px solid var(--color-dark-border);
  }
  .price-line {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .price-currency {
    font-size: 15px;
    font-weight: 500;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.06em;
  }
  .price {
    font-size: 44px;
    font-weight: 700;
    color: var(--color-white);
    line-height: 1;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
  }
  .featured .price {
    color: var(--color-primary);
  }
  .price-period {
    font-size: 14px;
    color: rgba(255,255,255,0.4);
  }
  .price-term {
    display: inline-block;
    margin-top: 10px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.45);
  }
  .features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }
  .features li {
    font-size: 14px;
    color: rgba(255,255,255,0.65);
    display: flex;
    align-items: flex-start;
    gap: 12px;
    line-height: 1.5;
  }
  .features li::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    flex-shrink: 0;
    margin-top: 8px;
  }
  .pricing-btn {
    width: 100%;
    justify-content: center;
    margin-top: auto;
    gap: 10px;
    transition: gap 0.25s ease, background 0.25s ease, border-color 0.25s ease, color 0.25s ease;
  }
  .pricing-btn:hover {
    gap: 14px;
  }

  .inclusions {
    margin-top: 80px;
    padding: 40px 48px;
    border: 1px solid var(--color-dark-border);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at top left, rgba(9,138,203,0.08), transparent 60%),
      var(--color-dark-surface);
  }
  .inclusions-head {
    margin-bottom: 32px;
    text-align: center;
  }
  .inclusions-eyebrow {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--color-primary);
    margin-bottom: 8px;
  }
  .inclusions-title {
    font-size: 24px;
    font-weight: 600;
    color: var(--color-white);
    letter-spacing: -0.02em;
  }
  .inclusions-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }
  .inclusion {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }
  .inclusion-icon {
    flex-shrink: 0;
    color: var(--color-primary);
    background: rgba(9,138,203,0.12);
    padding: 8px;
    border-radius: var(--radius-sm);
    box-sizing: content-box;
  }
  .inclusion-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-white);
    margin-bottom: 4px;
    line-height: 1.3;
  }
  .inclusion-text {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    line-height: 1.5;
  }

  @media (max-width: 1024px) {
    .pricing-grid-2 {
      grid-template-columns: 1fr;
      max-width: 480px;
    }
    .inclusions-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .inclusions {
      padding: 32px 24px;
    }
    .inclusions-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .pricing-body {
      padding: 24px 22px;
    }
    .price { font-size: 38px; }
  }
</style>
