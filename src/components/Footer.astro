---
const navLinks = [
  { text: 'Community', href: '/#community' },
  { text: 'Workspaces', href: '/#pricing' },
  { text: 'Ausstattung', href: '/#ausstattung' },
  { text: 'FAQ', href: '/#faq' },
  { text: 'Mietgesuch', href: '/#mietgesuch' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-left">
        <a href="/" class="footer-logo" aria-label="FactorAI Startseite">
          <img src="/images/factorai-logo.svg" alt="FactorAI" class="footer-logo-img" width="131" height="120" />
        </a>
        <p class="footer-address">Stelleweg 4, 7000 Chur Nord</p>
      </div>
      <nav class="footer-nav" aria-label="Footer Navigation">
        {navLinks.map(link => (
          <a href={link.href}>{link.text}</a>
        ))}
      </nav>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 FactorAI &middot; Chur Nord, Schweiz</p>
      <div class="footer-legal">
        <a href="/impressum">Impressum</a>
        <a href="/datenschutz">Datenschutz</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-dark);
    border-top: 1px solid var(--color-dark-border);
    padding: 48px 24px;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 40px;
  }
  .footer-logo {
    display: block;
    margin-bottom: 12px;
  }
  .footer-logo-img {
    height: 36px;
    width: auto;
  }
  .footer-address {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 8px;
  }
  .footer-nav {
    display: flex;
    gap: 24px;
  }
  .footer-nav a {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
  }
  .footer-nav a:hover {
    color: var(--color-primary);
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
    border-top: 1px solid var(--color-dark-border);
    font-size: 13px;
    color: rgba(255,255,255,0.3);
  }
  .footer-legal {
    display: flex;
    gap: 16px;
  }
  .footer-legal a {
    color: rgba(255,255,255,0.3);
    transition: color 0.2s;
  }
  .footer-legal a:hover {
    color: var(--color-primary);
  }
  @media (max-width: 768px) {
    .footer-inner {
      flex-direction: column;
      gap: 32px;
    }
    .footer-nav {
      flex-wrap: wrap;
      gap: 16px;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }
  }
</style>
