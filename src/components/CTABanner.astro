---
---

<section class="mietgesuch section" id="mietgesuch">
  <div class="container">
    <div class="form-grid">
      <div class="form-intro">
        <p class="label">Lass uns die Zukunft bauen</p>
        <h2>Jetzt Besichtigung vereinbaren</h2>
        <p class="form-desc">Suchst du nicht nur ein Büro, sondern ein echtes Netzwerk aus Gleichgesinnten? Dann bist du bei uns genau richtig. Komm vorbei, schau dir die frisch renovierte Location an und erzähl uns von deinen Projekten.</p>
        <div class="contact-details">
          <p class="contact-person">Dein Ansprechpartner: <strong>Sebastian Früh</strong></p>
          <div class="contact-links">
            <a href="mailto:FactorAIchur@pm.me" class="contact-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="22,4 12,13 2,4"/></svg>
              FactorAIchur@pm.me
            </a>
            <a href="https://instagram.com/FactorAI_chur" target="_blank" rel="noopener" class="contact-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
              @FactorAI_chur
            </a>
          </div>
        </div>
        <div class="form-image">
          <img src="/images/blue-hallway.jpg" alt="FactorAI Eingangsbereich in Chur Nord mit Sichtbeton und blauer Wand" loading="lazy" decoding="async" width="560" height="240" />
        </div>
      </div>
      <form class="mietgesuch-form" name="mietgesuch" method="POST" data-netlify="true" netlify action="/erfolg">
        <input type="hidden" name="form-name" value="mietgesuch" />
        <div class="form-group">
          <label for="name">Name &amp; Unternehmen</label>
          <input type="text" id="name" name="name" placeholder="Max Muster, Muster AI GmbH" required />
        </div>
        <div class="form-group">
          <label for="ki-fokus">Welche Rolle spielt KI in deinem Business?</label>
          <textarea id="ki-fokus" name="ki-fokus" rows="3" placeholder="Erzähl uns, wie du KI einsetzt oder einsetzen möchtest..."></textarea>
        </div>
        <div class="form-group">
          <label for="alltag">Beschreibe deinen Arbeitsalltag</label>
          <textarea id="alltag" name="alltag" rows="3" placeholder="Wie arbeitest du und was ist deine Vorstellung vom Zusammenleben im Workspace?"></textarea>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="workspace">Wunsch-Workspace</label>
            <select id="workspace" name="workspace">
              <option value="">Bitte wählen...</option>
              <option value="fix-desk">Fix-Desk #sharedoffice (CHF 249.–/Monat)</option>
              <option value="oberland-1">Einzelbüro Premium Oberland 1 (CHF 789.–)</option>
              <option value="oberland-2">Einzelbüro Premium Oberland 2 (CHF 789.–)</option>
              <option value="montalin-3">Einzelbüro Premium Montalin 3 (CHF 789.–)</option>
            </select>
          </div>
          <div class="form-group">
            <label for="besichtigung">Wunschtermin Besichtigung</label>
            <input type="text" id="besichtigung" name="besichtigung" placeholder="z.B. Montag Nachmittag" />
          </div>
        </div>
        <button type="submit" class="btn btn-primary form-submit">Anfrage senden</button>
      </form>
    </div>
  </div>
</section>

<style>
  .mietgesuch {
    background: var(--color-white);
  }
  .label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .form-intro h2 {
    font-size: 36px;
    font-weight: 700;
    margin-bottom: 16px;
  }
  .form-desc {
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-gray-500);
    margin-bottom: 24px;
  }
  .contact-details {
    margin-bottom: 32px;
  }
  .contact-person {
    font-size: 15px;
    color: var(--color-gray-500);
    margin-bottom: 12px;
  }
  .contact-person strong {
    color: var(--color-black);
  }
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-primary);
    transition: opacity 0.2s;
  }
  .contact-link:hover {
    opacity: 0.8;
  }
  .contact-link svg {
    flex-shrink: 0;
  }
  .form-image {
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .form-image img {
    width: 100%;
    height: 240px;
    object-fit: cover;
  }
  .mietgesuch-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .form-group label {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-black);
  }
  .form-group input,
  .form-group textarea,
  .form-group select {
    font-family: var(--font-main);
    font-size: 15px;
    padding: 12px 16px;
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-sm);
    background: var(--color-gray-100);
    color: var(--color-black);
    transition: border-color 0.2s;
  }
  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    outline: none;
    border-color: var(--color-primary);
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .form-submit {
    width: 100%;
    justify-content: center;
    padding: 16px;
    font-size: 16px;
    font-weight: 600;
  }
  @media (max-width: 768px) {
    .form-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .form-intro h2 { font-size: 28px; }
    .form-row { grid-template-columns: 1fr; }
    .form-image { display: none; }
  }
</style>
