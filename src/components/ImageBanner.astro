---
---

<section class="gallery section" id="gallery">
  <div class="container">
    <div class="gallery-head">
      <div>
        <p class="label">Einblicke</p>
        <h2 class="gallery-title">Stelleweg&nbsp;4, <em>7000 Chur Nord</em></h2>
      </div>
      <p class="gallery-sub">210&nbsp;m² Dachgeschoss &ndash; Sichtbeton, Echtholz-Parkett, Panoramablick auf die Bündner Alpen.</p>
    </div>

    <div class="gallery-grid">
      <figure class="tile tile-tall">
        <img src="/images/meeting-room-mountains.jpg" alt="FactorAI Meeting-Raum mit Panoramafenstern auf den Calanda" loading="lazy" decoding="async" width="560" height="680" />
        <figcaption>Meeting-Raum &middot; Bergblick</figcaption>
      </figure>
      <figure class="tile">
        <img src="/images/blue-hallway.jpg" alt="FactorAI Korridor mit blauer Wand und Sichtbeton" loading="lazy" decoding="async" width="560" height="320" />
        <figcaption>Korridor &middot; Sichtbeton</figcaption>
      </figure>
      <figure class="tile">
        <img src="/images/einzelbuero-montalin.jpg" alt="Einzelbüro Montalin mit Bergblick in Chur" loading="lazy" decoding="async" width="560" height="320" />
        <figcaption>Einzelbüro Montalin</figcaption>
      </figure>
      <figure class="tile tile-wide">
        <img src="/images/einzelbuero-oberland.jpg" alt="Einzelbüro Oberland mit Blick auf den Calanda" loading="lazy" decoding="async" width="1140" height="380" />
        <figcaption>Einzelbüro Oberland &middot; Ausblick</figcaption>
      </figure>
    </div>

    <div class="gallery-foot">
      <p>Lust auf eine Tour vor Ort?</p>
      <a href="#mietgesuch" class="btn btn-primary">Besichtigung vereinbaren <span aria-hidden="true">&rarr;</span></a>
    </div>
  </div>
</section>

<style>
  .gallery {
    background: var(--color-white);
    padding-bottom: 100px;
  }
  .gallery-head {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: 48px;
    align-items: end;
    margin-bottom: 40px;
  }
  .label {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 2.5px;
    margin-bottom: 12px;
  }
  .gallery-title {
    font-size: clamp(32px, 4.5vw, 44px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }
  .gallery-title em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-primary);
  }
  .gallery-sub {
    font-size: 16px;
    color: var(--color-gray-500);
    line-height: 1.65;
    max-width: 420px;
    justify-self: end;
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: 340px 340px;
    gap: 12px;
  }
  .tile {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    margin: 0;
  }
  .tile-tall {
    grid-row: span 2;
  }
  .tile-wide {
    grid-column: span 2;
    grid-row: auto;
  }
  .tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(.2,.8,.2,1);
  }
  .tile:hover img {
    transform: scale(1.04);
  }
  .tile::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(12,12,18,0.6) 100%);
    pointer-events: none;
  }
  .tile figcaption {
    position: absolute;
    bottom: 16px;
    left: 18px;
    padding: 6px 14px;
    background: rgba(12,12,18,0.55);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-full);
    font-size: 12px;
    font-weight: 500;
    color: var(--color-white);
    letter-spacing: 0.01em;
    z-index: 1;
  }
  .gallery-foot {
    margin-top: 40px;
    padding: 28px 32px;
    background: var(--color-black);
    border-radius: var(--radius-md);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .gallery-foot p {
    font-size: 18px;
    font-weight: 500;
    color: var(--color-white);
  }

  @media (max-width: 1024px) {
    .gallery-head {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .gallery-sub { justify-self: start; }
  }
  @media (max-width: 640px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      grid-template-rows: 240px 240px 240px 240px;
    }
    .tile-tall, .tile-wide { grid-column: auto; grid-row: auto; }
    .gallery-foot { padding: 22px; }
    .gallery-foot p { font-size: 16px; }
  }
</style>
