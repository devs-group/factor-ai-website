---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import ImageBanner from '../components/ImageBanner.astro';
import Pricing from '../components/Pricing.astro';
import WhyUs from '../components/WhyUs.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://factor-ai.ch/#org",
      "name": "FactorAI",
      "url": "https://factor-ai.ch",
      "logo": "https://factor-ai.ch/images/factorai-logo.svg",
      "email": "FactorAIchur@pm.me",
      "sameAs": ["https://instagram.com/FactorAI_chur"],
      "founder": { "@id": "https://factor-ai.ch/#sebastian" }
    },
    {
      "@type": "WebSite",
      "@id": "https://factor-ai.ch/#website",
      "url": "https://factor-ai.ch",
      "name": "FactorAI",
      "inLanguage": "de-CH",
      "publisher": { "@id": "https://factor-ai.ch/#org" }
    },
    {
      "@type": "Person",
      "@id": "https://factor-ai.ch/#sebastian",
      "name": "Sebastian Früh",
      "jobTitle": "Gründer",
      "worksFor": { "@id": "https://factor-ai.ch/#org" },
      "alumniOf": {
        "@type": "CollegeOrUniversity",
        "name": "Fachhochschule Graubünden",
        "url": "https://www.fhgr.ch"
      },
      "knowsAbout": ["Künstliche Intelligenz", "Coworking", "Unternehmertum", "IT-Consulting"],
      "image": "https://factor-ai.ch/images/founder-signature-wall.jpg"
    },
    {
      "@type": ["LocalBusiness", "CoworkingSpace"],
      "@id": "https://factor-ai.ch/#business",
      "name": "FactorAI",
      "description": "FactorAI ist der Maker Place am Stelleweg 4 in Chur Nord für KI-affine Unternehmer/innen, IT-Consultants und Tech-Visionäre. Fix-Desks, Einzelbüros und eine exklusive Tech-Community auf 210 m².",
      "url": "https://factor-ai.ch",
      "image": [
        "https://factor-ai.ch/images/founder-signature-wall.jpg",
        "https://factor-ai.ch/images/meeting-room-mountains.jpg",
        "https://factor-ai.ch/images/einzelbuero-oberland.jpg"
      ],
      "logo": "https://factor-ai.ch/images/factorai-logo.svg",
      "email": "FactorAIchur@pm.me",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Stelleweg 4",
        "addressLocality": "Chur",
        "postalCode": "7000",
        "addressRegion": "GR",
        "addressCountry": "CH"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 46.8618,
        "longitude": 9.5215
      },
      "hasMap": "https://www.google.com/maps?q=Stelleweg+4,+7000+Chur",
      "areaServed": [
        { "@type": "City", "name": "Chur" },
        { "@type": "AdministrativeArea", "name": "Graubünden" }
      ],
      "knowsAbout": ["Coworking Chur", "Einzelbüro Chur", "Büro mieten Chur", "KI Community", "Deep Work"],
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "08:00",
        "closes": "22:00"
      },
      "priceRange": "CHF",
      "founder": { "@id": "https://factor-ai.ch/#sebastian" },
      "sameAs": ["https://instagram.com/FactorAI_chur"],
      "makesOffer": [
        {
          "@type": "Offer",
          "name": "Fix-Desk #sharedoffice",
          "description": "Fester Schreibtisch im Gemeinschaftsbüro, monatlich kündbar.",
          "price": "249",
          "priceCurrency": "CHF",
          "priceSpecification": {
            "@type": "UnitPriceSpecification",
            "price": "249",
            "priceCurrency": "CHF",
            "unitCode": "MON",
            "referenceQuantity": { "@type": "QuantitativeValue", "value": "1", "unitCode": "MON" }
          },
          "availability": "https://schema.org/InStock",
          "url": "https://factor-ai.ch/#pricing"
        },
        {
          "@type": "Offer",
          "name": "Einzelbüro Premium",
          "description": "Voll möbliertes privates Einzelbüro (Oberland 1 & 2 bis 2 Personen, Montalin 3 bis 3 Personen), alle 3 Monate kündbar.",
          "price": "789",
          "priceCurrency": "CHF",
          "priceSpecification": {
            "@type": "UnitPriceSpecification",
            "price": "789",
            "priceCurrency": "CHF",
            "unitCode": "MON"
          },
          "availability": "https://schema.org/InStock",
          "url": "https://factor-ai.ch/#pricing"
        }
      ]
    },
    {
      "@type": "Event",
      "@id": "https://factor-ai.ch/#opening",
      "name": "FactorAI Eröffnung",
      "startDate": "2026-06-01",
      "endDate": "2026-06-30",
      "eventStatus": "https://schema.org/EventScheduled",
      "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
      "location": {
        "@type": "Place",
        "name": "FactorAI",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Stelleweg 4",
          "addressLocality": "Chur",
          "postalCode": "7000",
          "addressCountry": "CH"
        }
      },
      "image": "https://factor-ai.ch/images/founder-signature-wall.jpg",
      "description": "Offizielle Eröffnung des FactorAI Maker Place in Chur Nord.",
      "organizer": { "@id": "https://factor-ai.ch/#org" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Was ist FactorAI?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "FactorAI ist ein hochspezialisierter Maker Place in Chur Nord am Stelleweg 4. Auf 210 m² lichtdurchfluteter Dachgeschossfläche bieten wir Fix-Desks und private Einzelbüros für KI-affine Unternehmer/innen in einer exklusiven Tech-Community."
          }
        },
        {
          "@type": "Question",
          "name": "Für wen ist FactorAI geeignet?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Für KI-affine Unternehmer/innen, IT-Consultants, Freelancer und Tech-Teams, die einen professionellen Workspace mit Gleichgesinnten suchen. Wir setzen bewusst auf feste Arbeitsplätze statt anonyme Flex-Desks."
          }
        },
        {
          "@type": "Question",
          "name": "Was ist in der Miete enthalten?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Unser Rundum-sorglos-Paket ist immer inklusive: höhenverstellbarer Tisch, ergonomischer Bürostuhl, hochwertige Stehlampe, Highspeed-WiFi, Strom und Nebenkosten sowie die Reinigung der Gemeinschaftsflächen (Küche/WCs). Keine versteckten Kosten."
          }
        },
        {
          "@type": "Question",
          "name": "Was kosten Fix-Desk und Einzelbüro?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Der Fix-Desk im #sharedoffice kostet CHF 249.–/Monat und ist monatlich kündbar. Das Einzelbüro Premium (Oberland 1 & 2 für bis zu 2 Personen oder Montalin 3 für bis zu 3 Personen) kostet CHF 789.–/Monat und ist alle 3 Monate kündbar."
          }
        },
        {
          "@type": "Question",
          "name": "Wie flexibel sind die Verträge?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Der Fix-Desk im #sharedoffice hat eine Kündigungsfrist von nur einem Monat. Die Einzelbüros Premium haben eine Kündigungsfrist von 3 Monaten."
          }
        },
        {
          "@type": "Question",
          "name": "Kann ich eine Besichtigung machen?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Natürlich! Nutze das Kontaktformular unten oder schreib uns direkt an FactorAIchur@pm.me. Wir zeigen dir gerne die Räumlichkeiten und stellen dich der Community vor."
          }
        },
        {
          "@type": "Question",
          "name": "Gibt es Parkplätze?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ja, Parkplätze können für CHF 99.–/Monat dazu gemietet werden. Die Lage direkt beim Autobahnanschluss Chur Nord ist auch mit ÖV bestens erreichbar (Bushaltestelle 50 m entfernt)."
          }
        }
      ]
    }
  ]
};
---

<BaseLayout schema={schema}>
  <Header />
  <Hero />
  <Services />
  <ImageBanner />
  <Pricing />
  <WhyUs />
  <Testimonials />
  <FAQ />
  <CTABanner />
  <Footer />
</BaseLayout>
