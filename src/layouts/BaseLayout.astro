---
const {
  title = "Coworking Chur & Einzelbüro am Stelleweg 4 | FactorAI",
  description = "Coworking & Einzelbüros in Chur Nord: Fix-Desk ab CHF 249.–, Einzelbüro Premium ab CHF 789.–. Maker Place für KI-affine Unternehmer/innen auf 210 m².",
  canonical,
  noindex = false,
  ogImage = "/images/founder-signature-wall.jpg",
  schema,
} = Astro.props;

const siteUrl = "https://factor-ai.ch";
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;
---
<!DOCTYPE html>
<html lang="de-CH">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0C0C12" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="de_CH" />
  <meta property="og:site_name" content="FactorAI" />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  <!-- Geo / Local -->
  <meta name="geo.region" content="CH-GR" />
  <meta name="geo.placename" content="Chur" />
  <meta name="ICBM" content="46.8618, 9.5215" />
  <link rel="icon" type="image/svg+xml" href="/images/factorai-logo.svg" />
  <link rel="apple-touch-icon" href="/images/factorai-logo.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="image" href="/images/founder-signature-wall.jpg" fetchpriority="high" />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" /></noscript>
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
</head>
<body>
  <a href="#hero" class="skip-link">Zum Inhalt springen</a>
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
