---
const {
  title = "FactorAI | Der inCHURbation Space for Makers in Chur Nord",
  description = "FactorAI ist der Maker Place am Stelleweg 4 in Chur Nord für KI-affine Unternehmer/innen, IT-Consultants und Tech-Visionäre. Fix-Desks, Einzelbüros und eine exklusive Tech-Community auf 210 m².",
  canonical,
  noindex = false,
} = Astro.props;

const siteUrl = "https://factor-ai.ch";
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="de_CH" />
  <meta property="og:site_name" content="FactorAI" />
  <link rel="icon" type="image/svg+xml" href="/images/factorai-logo.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
